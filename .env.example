# ARIA-OS — Backend environment (template)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env` and fill in real values. `.env` is gitignored — NEVER commit it.
# In production load these from a secret manager (Cloud Run Secret Manager /
# Render env-groups), NOT from a file. Variables marked [secret] must live in the
# secret manager; the rest are plain config.
#
# Key naming note: ARIA-OS uses InsForge (NOT Supabase). The server uses the
# InsForge *secret* key (INSFORGE_API_KEY). Never use legacy `service_role`/`anon`
# JWTs. The browser publishable key lives only in the frontend
# (NEXT_PUBLIC_INSFORGE_ANON_KEY — see frontend/.env.local.example).

# ── InsForge backend (PostgREST + auth) ──────────────────────────────────────
INSFORGE_URL=https://<your-project>.<region>.insforge.app
INSFORGE_API_KEY=                 # [secret] InsForge Studio → Settings → API Keys → Secret key
INSFORGE_JWT_SECRET=              # [secret] verifies InsForge-issued JWTs (auth)
INSFORGE_AI_MODEL=gemini-2.5-flash   # model id used by the agent (has a sane default)

# ── LLM (Google Gemini via AI Studio) ────────────────────────────────────────
GEMINI_API_KEY=                   # [secret] https://aistudio.google.com/apikey

# ── Crypto ───────────────────────────────────────────────────────────────────
# [secret] Fernet key used to encrypt per-tenant integration credentials
# (tenant_integrations). Rotating this re-breaks decryption of stored WooCommerce
# creds — only rotate while re-encrypting those rows. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ARIA_ENCRYPTION_KEY=

# ── Cron + webhooks ──────────────────────────────────────────────────────────
CRON_SECRET=                      # [secret] sent as X-Cron-Secret by the external scheduler
WEBHOOK_SECRET=                   # [secret] verifies inbound webhook signatures

# ── WooCommerce (global fallback only) ───────────────────────────────────────
# Per-tenant store credentials are stored encrypted in `tenant_integrations`.
# These globals are an optional single-store fallback for local dev.
WOOCOMMERCE_API_URL=
WOOCOMMERCE_API_KEY=              # [secret]
WOOCOMMERCE_API_SECRET=           # [secret]

# ── HTTP / CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000   # comma-separated origins allowed by CORS

# ── Local paths (optional — have defaults under the repo) ────────────────────
ARIA_MEMORY_DIR=                  # HAM memory dir (default: ./.aria/memory)
ARIA_SKILLS_DIR=                  # synthesized skills dir (default: ./.aria/skills)

# ── Demo / dev toggles ───────────────────────────────────────────────────────
ARIA_ALLOW_DEMO_FALLBACK=0        # 1 = allow demo fallback data when DB empty (dev only)
