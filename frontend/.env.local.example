# ARIA-OS — Frontend environment (template)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `frontend/.env.local` and fill in real values. `.env.local` is
# gitignored — NEVER commit it. Only NEXT_PUBLIC_* values reach the browser; keep
# anything sensitive out of this file.

# InsForge auth (browser). The ANON key here is the *publishable* key — safe for
# the client (NOT the secret key, which stays server-side in the backend .env).
NEXT_PUBLIC_INSFORGE_URL=https://<your-project>.<region>.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# Where the browser reaches the FastAPI backend (public base URL).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Server-side (Next.js route handlers): the agent/CopilotKit proxy target.
AGENT_URL=http://localhost:8080
